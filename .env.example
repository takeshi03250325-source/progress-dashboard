# === 必須 ===
MAGAZINE_LINEAR_API_KEY=lin_api_xxxxx
MAGAZINE_LINEAR_TEAM_KEY=YOUR_TEAM
MAGAZINE_GEMINI_API_KEY=xxxxx
# ダッシュボード（npm run ai-suggestions）と朝ニュース文案（npm run morning:fetch）の両方で使用
# CI（morning-news.yml）でも MAGAZINE_GEMINI_API_KEY を Repository secrets に登録
MAGAZINE_SLACK_BOT_TOKEN=xoxb-xxxxx
MAGAZINE_SLACK_CHANNEL_ID=C0XXXXXXXXX
MAGAZINE_SURGE_LOGIN=your-email@example.com
MAGAZINE_SURGE_TOKEN=xxxxx
MAGAZINE_SURGE_DOMAIN=your-project-dashboard.surge.sh

# === オプション ===
# MAGAZINE_GEMINI_MODEL=models/gemini-2.5-flash
# MAGAZINE_SURGE_CDN_WAIT_MS=10000

# === LINE Messaging API（朝ニュースのプッシュ・Webhook で「NG」→次候補）===
# このファイルをコピーして .env を作り、下に実値を書く（.env は Git に含めない）
# LINE_CHANNEL_ID=
# Webhook 署名検証に必須（チャネル基本設定のチャネルシークレット）
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_PUSH_TO_USER_ID=（プッシュ先のユーザー ID。友だち追加後に取得）
# npm run morning:webhook の待受ポート（省略時 3333）
# LINE_WEBHOOK_PORT=3333
